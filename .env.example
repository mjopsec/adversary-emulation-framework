# ============================================================
#  AE Platform — Environment Configuration Template
#  Copy this file to .env and fill in the values.
#  NEVER commit .env to version control.
# ============================================================

# ─── Application ──────────────────────────────────────────
APP_NAME="AE Platform"
APP_VERSION="1.0.0"
DEBUG=false

# ─── API Server ───────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
SECRET_KEY=ganti-dengan-secret-key-yang-kuat-dan-acak

# ─── Database ─────────────────────────────────────────────
# SQLite untuk development
DATABASE_URL=sqlite+aiosqlite:///./aep.db

# PostgreSQL untuk production (uncomment dan sesuaikan)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aep_db

# ─── AI Engine (Anthropic Claude) — opsional ──────────────
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4096

# ─── Shannon AI (Red Team AI) — untuk generate payload examples
SHANNON_API_KEY=sk-...
SHANNON_BASE_URL=https://api.shannon-ai.com/v1
SHANNON_MODEL=shannon-1.6-pro

# ─── MITRE ATT&CK Data ────────────────────────────────────
ATTACK_DATA_DIR=data/attack
ENTERPRISE_ATTACK_FILE=enterprise-attack.json
ICS_ATTACK_FILE=ics-attack.json

# ─── Operational Safety ───────────────────────────────────
# true = OT write operations diblokir kecuali ada izin eksplisit
DEFAULT_PRODUCTION_SAFE=true

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/aep.log
